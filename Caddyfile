# HomePanel reverse proxy on home.offlabs.cc.
# Caddy obtains and renews a Let's Encrypt cert automatically.
# Replace the email below before deploying.

{
    email you@offlabs.cc
    servers {
        protocols h1 h2 h3
    }
}

home.offlabs.cc {
    encode zstd gzip

    # Hard cap on auth endpoints — defence in depth on top of the app-level limiter.
    @auth path /api/auth/*
    rate_limit @auth {
        zone auth_zone
        events 30
        window 1m
    }

    reverse_proxy app:3000 {
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-Host {host}
    }

    header {
        # Caddy adds HSTS automatically when TLS is active, but be explicit.
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
        Referrer-Policy same-origin
        # Don't leak server identification.
        -Server
    }

    log {
        output stdout
        format json
    }
}
