# HomePanel reverse proxy. Replace YOUR_DOMAIN and YOUR_EMAIL before deploying.
# Caddy obtains and renews a Let's Encrypt cert automatically.

{
    email YOUR_EMAIL
    servers {
        protocols h1 h2 h3
    }
}

YOUR_DOMAIN {
    encode zstd gzip

    reverse_proxy app:3000 {
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-Host {host}
    }

    header {
        # Caddy adds HSTS automatically when TLS is active, but be explicit.
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
        Referrer-Policy same-origin
        # Don't leak server identification.
        -Server
    }

    log {
        output stdout
        format json
    }
}
