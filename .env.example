# Copy to .env on the deploy host and fill in. Never commit .env.

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Public URL the app is served from. No trailing slash.
AUTH_URL=https://home.offlabs.cc

# Required when running behind a reverse proxy (Caddy, nginx, etc.).
AUTH_TRUST_HOST=true

# --- Discord OAuth ---
# Create an app at https://discord.com/developers/applications
# OAuth2 → Redirects → add:  https://home.offlabs.cc/api/auth/callback/discord
#                            http://localhost:3000/api/auth/callback/discord  (for local dev)
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# --- Allow-list ---
# Comma-separated Discord user IDs that may sign in.
# Discord Settings → Advanced → Developer Mode (on), then right-click your profile → Copy User ID.
ALLOWED_DISCORD_IDS=

# Pretty display names mapped to Discord IDs. Format: <id>:Name,<id>:Name
# Drives the colored pill names. Falls back to Discord's global_name if missing.
DISPLAY_NAMES=

# --- Database ---
# SQLite file path relative to the app working dir. The data/ folder is gitignored.
DATABASE_URL=file:./data/homepanel.db
