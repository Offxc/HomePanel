# Copy to .env on the deploy host and fill in. Never commit .env.

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Public URL the app is served from. No trailing slash.
AUTH_URL=https://your-domain.example.com

# Required when running behind a reverse proxy (Caddy, nginx, etc.).
AUTH_TRUST_HOST=true

# --- Discord OAuth ---
# Create an app at https://discord.com/developers/applications
# OAuth2 → Redirects → add:  https://your-domain.example.com/api/auth/callback/discord
#                            http://localhost:3000/api/auth/callback/discord  (for local dev)
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# --- Allow-list ---
# Comma-separated Discord user IDs that may sign in.
# Discord Settings → Advanced → Developer Mode (on), then right-click your profile → Copy User ID.
ALLOWED_DISCORD_IDS=

# Pretty display names mapped to Discord IDs. Format: <id>:Name,<id>:Name
# Drives the colored pill names. Falls back to Discord's global_name if missing.
DISPLAY_NAMES=

# --- Database ---
# SQLite file path relative to the app working dir. The data/ folder is gitignored.
DATABASE_URL=file:./data/homepanel.db

# Public URL shown in bot embed footers (no trailing slash, no https://).
APP_PUBLIC_URL=your-domain.example.com

# --- Discord bot (daily digest) ---
# Enable the Bot feature on your existing Discord app:
#   discord.com/developers/applications → your app → Bot → Add Bot → copy token
DISCORD_BOT_TOKEN=

# Channel IDs where each person's daily digest is posted.
# Enable Developer Mode in Discord (Settings → Advanced → Developer Mode),
# then right-click the target channel → Copy Channel ID.
DISCORD_CHANNEL_OFF=
DISCORD_CHANNEL_BRI=

# Shared secret between the app and the bot for the internal digest API.
# Generate with:  openssl rand -base64 32
INTERNAL_API_SECRET=
